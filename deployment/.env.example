# 竹林司马应用环境变量示例
# 复制此文件为 .env 并根据需要修改

# ========== 应用配置 ==========
APP_ENV=development
APP_PORT=8000
APP_NAME=竹林司马
APP_VERSION=1.0.0
APP_DESCRIPTION=竹林司马 - 短视频创作与管理系统
APP_DEBUG=true

# ========== 数据库配置 ==========
DATABASE_URL=postgresql://postgres:password@localhost:5432/zhulinsma
POSTGRES_DB=zhulinsma
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DB_PORT=5432

# ========== Redis配置 ==========
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 安全配置 ==========
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========== 文件存储配置 ==========
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
STORAGE_PROVIDER=local  # local, s3, azure, google
S3_BUCKET=zhulinsma-files
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ========== 邮件配置 ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@zhulinsma.com
EMAIL_ENABLED=false

# ========== 第三方服务配置 ==========
OPENAI_API_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ========== 监控配置 ==========
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ========== pgAdmin配置 ==========
PGADMIN_EMAIL=admin@zhulinsma.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ========== 功能开关 ==========
ENABLE_CACHE=true
ENABLE_QUEUE=true
ENABLE_WEBSOCKET=true
ENABLE_MONITORING=true
ENABLE_SOCIAL=true
ENABLE_SEARCH=true
ENABLE_STORAGE=true

# ========== 部署配置 ==========
DEPLOY_ENV=staging  # development, staging, production
CDN_URL=https://cdn.zhulinsma.com
API_BASE_URL=https://api.zhulinsma.com
WEB_BASE_URL=https://app.zhulinsma.com