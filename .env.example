# 应用配置
APP_NAME="竹林司马后端"
APP_ENV="development"  # development, staging, production
APP_VERSION="1.0.0"
APP_DEBUG="true"
APP_SECRET_KEY="change-this-in-production-with-secure-random-key"
APP_ALLOWED_HOSTS="localhost,127.0.0.1"
APP_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# 数据库配置
DATABASE_URL="postgresql://zhulin:password@localhost:5432/zhulinsma"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_RECYCLE=3600

# Redis配置
REDIS_URL="redis://localhost:6379/0"
REDIS_PASSWORD=""
REDIS_POOL_SIZE=10

# RabbitMQ配置
RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# JWT配置
JWT_SECRET_KEY=${APP_SECRET_KEY}
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 文件存储配置
FILE_UPLOAD_MAX_SIZE=104857600  # 100MB
FILE_STORAGE_PROVIDER="local"  # local, s3, minio
FILE_STORAGE_PATH="./uploads"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="zhulinsma"
AWS_S3_REGION="ap-guangzhou"
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"

# 邮件配置
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@zhulinsma.com"
SMTP_USE_TLS="true"

# 监控配置
SENTRY_DSN=""
PROMETHEUS_METRICS_PORT=9090
GRAFANA_URL="http://localhost:3000"

# 第三方API配置
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 速率限制配置
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_DEFAULT="100/minute"
RATE_LIMIT_AUTH="10/minute"
RATE_LIMIT_UPLOAD="20/5minutes"

# 安全配置
SECURE_COOKIES="false"
CSP_ENABLED="false"
HSTS_ENABLED="false"

# 日志配置
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_FILE="./logs/app.log"